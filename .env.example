# SerpAPI — Google Jobs search
# Get a free key at: https://serpapi.com
SERPAPI_API_KEY=your_serpapi_key_here

# Hunter.io — recruiter/founder email discovery
# Get a free key at: https://hunter.io
HUNTER_API_KEY=your_hunter_key_here

# Gmail SMTP — sending outreach emails
# Use a Gmail App Password (NOT your account password)
# Generate at: myaccount.google.com/apppasswords
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# AWS credentials — only needed if using DraupLLMManager (Draup internal)
# For public use, swap DraupLLMManager for litellm directly with GEMINI_API_KEY
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-1

# Alternative: direct Gemini API key (for public fork of this project)
# GEMINI_API_KEY=your_gemini_key_here
